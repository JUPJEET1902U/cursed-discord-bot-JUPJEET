# ── Discord Bot ────────────────────────────────────────────────────────────────
BOT_TOKEN=your_discord_bot_token_here
BOT_OWNER_IDS=your_discord_user_id_here

# ── AI Providers ───────────────────────────────────────────────────────────────
GROQ_KEY=your_groq_api_key_here
GEMINI_KEY=your_gemini_api_key_here

# ── Database ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/cursed

# ── Image Generation (optional) ───────────────────────────────────────────────
HF_TOKEN=your_huggingface_token_here

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
API_PORT=3001

# ── Dashboard OAuth ────────────────────────────────────────────────────────────
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret
DISCORD_REDIRECT_URI=http://localhost:5173/auth/callback
DASHBOARD_URL=http://localhost:5173

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Webhook Signature Secrets (optional but strongly recommended) ──────────────
# Set these to the secret/token configured in each platform's webhook settings.
# If set, incoming webhooks without a valid HMAC signature will be rejected (401).
# WEBHOOK_KOFI_SECRET=your_kofi_verification_token
# WEBHOOK_PATREON_SECRET=your_patreon_webhook_secret
# WEBHOOK_BMC_SECRET=your_bmc_webhook_secret

# ── API Rate Limiting (optional) ───────────────────────────────────────────────
# API_RATE_LIMIT_WINDOW_MS=900000   # 15 minutes (default)
# API_RATE_LIMIT_MAX=200            # max requests per window (default)

# ── Optional ───────────────────────────────────────────────────────────────────
# DEFAULT_ROLE_ID=role_id_to_assign_on_join
# MOD_LOG_CHANNEL_ID=channel_id_for_mod_logs (global fallback; per-guild config takes priority)
