# Discord bot
BOT_TOKEN=your_discord_bot_token_here
BOT_OWNER_IDS=your_discord_user_id_here

# MongoDB. Include the CURSED database name in this URI.
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/cursed

# Vercel dashboard integration.
# Generate a random value of at least 32 characters and use the same value in Railway and Vercel.
DASHBOARD_API_SECRET=
DASHBOARD_URL=https://cursed-discord-bot-dashboard.vercel.app
GUILD_CONFIG_REFRESH_MS=5000
GUILD_CONFIG_MIRROR_JSON=true

# AI providers (optional; fallback order is Gemini, Groq, OpenRouter)
GEMINI_KEY=
GROQ_KEY=
OPENROUTER_KEY=

# Image generation (optional)
HF_TOKEN=

# Railway supplies PORT automatically. Use 3000 for local development.
PORT=3000
NODE_ENV=production

# Existing dashboard OAuth fields used by the standalone legacy API (optional)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=

# Logging and optional global fallbacks
LOG_LEVEL=INFO
# DEFAULT_ROLE_ID=
# MOD_LOG_CHANNEL_ID=

# Payment verification secrets.
# Each configured secret must be at least 24 characters. Missing/short secrets disable only that webhook.
KOFI_WEBHOOK_SECRET=
PATREON_WEBHOOK_SECRET=
BMC_WEBHOOK_SECRET=
