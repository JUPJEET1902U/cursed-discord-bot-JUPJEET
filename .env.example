# ─── CURSED Bot — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit your .env file to version control.

# ─── Required ─────────────────────────────────────────────────────────────────

# Discord bot token (from https://discord.com/developers/applications)
BOT_TOKEN=your_discord_bot_token_here

# Groq API key (primary AI provider — https://console.groq.com)
GROQ_KEY=your_groq_api_key_here

# ─── Optional AI ──────────────────────────────────────────────────────────────

# Gemini API key (fallback AI provider — https://aistudio.google.com)
# If not set, the bot will only use Groq
GEMINI_KEY=your_gemini_api_key_here

# Hugging Face token (for !imagine and !meme image generation)
# Get one at https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_token_here

# ─── Optional Database ────────────────────────────────────────────────────────

# MongoDB connection URI (optional — bot works with JSON files by default)
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/cursed

# ─── Optional Server ──────────────────────────────────────────────────────────

# Port for the webhook/health server (default: 3000)
PORT=3000

# ─── Optional Bot Config ──────────────────────────────────────────────────────

# Mod-log channel ID (can also be set with !setmodlog command)
# MOD_LOG_CHANNEL_ID=your_channel_id_here

# Default role ID to assign to new members
# DEFAULT_ROLE_ID=your_role_id_here

# ─── Logging ──────────────────────────────────────────────────────────────────

# Log level: DEBUG | INFO | WARN | ERROR (default: INFO)
# LOG_LEVEL=INFO
