# Discord OAuth Application credentials
VITE_DISCORD_CLIENT_ID=your_discord_application_client_id

# Redirect URI — only set this for local development.
# In production (Vercel), leave this unset: the app automatically uses
# window.location.origin + /auth/callback, which matches your deployed domain.
# Must match exactly what is registered in your Discord Application's OAuth2 redirect URIs.
# VITE_REDIRECT_URI=http://localhost:5173/auth/callback

# API URL (where the backend API runs)
# Production (Railway): https://your-api.railway.app
# Local development: http://localhost:3001
VITE_API_URL=https://your-api.railway.app
