{
  "name": "cursed-bot",
  "version": "2.0.0",
  "description": "CURSED Discord Bot — AI-powered with full dashboard",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "api:start": "npx tsx api/server.ts",
    "api:dev": "npx tsx --watch api/server.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:dashboard-api": "node --test test/dashboard-api.test.js",
    "test:premium": "node --test test/premium-plans.test.js",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build"
  },
  "keywords": ["discord", "bot", "ai", "cursed"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@napi-rs/canvas": "^1.0.2",
    "cors": "^2.8.5",
    "discord.js": "^14.26.4",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "mongoose": "^8.0.0",
    "openai": "^6.42.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
